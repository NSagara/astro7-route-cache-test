---
export const prerender = false;

Astro.cache.set({
  maxAge: 60 * 60,
  tags: ['wp-test'],
});

const response = await fetch(
  'https://images.tatemono.photo/wp-json/wp/v2/posts?per_page=1&_fields=id,slug,date,modified,title'
);

if (!response.ok) {
  throw new Error(`WordPress API Error: ${response.status}`);
}

const posts = await response.json();
const post = posts[0];

const generatedAt = new Date().toISOString();
const randomValue = Math.random();
---

<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <title>WordPress Route Cache Test</title>
  </head>

  <body>
    <main>
      <h1>WordPress Route Cache Test</h1>

      <p>Post ID: {post.id}</p>
      <p>Slug: {post.slug}</p>
      <p>Title: {post.title.rendered}</p>
      <p>Published: {post.date}</p>
      <p>Modified: {post.modified}</p>

      <hr />

      <p>Generated At: {generatedAt}</p>
      <p>Random Value: {randomValue}</p>
    </main>
  </body>
</html>